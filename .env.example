# Copy this file to .env (or keep the root .env — the server finds it automatically)

GROQ_API_KEY=gsk_...
weather=your_openweathermap_key_here

# Vector store: Supabase / pgvector (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_or_secret_key

# Google Drive sync (auto-import documents from a shared Drive folder)
# Paste the full service account JSON as one line, OR place a
# drive-service-account.json file in backend/ for local dev (gitignored).
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=your_shared_folder_id_here
